generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Models
model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  password      String
  emailVerified Boolean
  image         String?

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
